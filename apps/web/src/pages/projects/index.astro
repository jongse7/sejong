---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { isProjectPost } from "@/utils/postGrouping";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const projects = getSortedPosts(posts).filter(isProjectPost);
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Projects" pageDesc="Selected work and project posts.">
    {projects.length > 0 ? (
      <ul>
        {projects.map(data => <Card {...data} />)}
      </ul>
    ) : (
      <p class="opacity-80">No projects yet. Add tag `project` to a post.</p>
    )}
  </Main>
  <Footer />
</Layout>
